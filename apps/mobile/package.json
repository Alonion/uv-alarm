{
  "name": "@uv-alarm/mobile",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint src vite.config.ts capacitor.config.ts",
    "test": "vitest run",
    "android:sync": "corepack pnpm build && cap sync android",
    "android:open": "cap open android",
    "android:debug": "corepack pnpm android:sync && cd android && gradlew.bat assembleDebug"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.2",
    "@capacitor/app": "^8.0.0",
    "@capacitor/core": "^8.4.2",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/local-notifications": "^8.2.1",
    "@capacitor/preferences": "^8.0.0",
    "@capacitor/push-notifications": "^8.1.2",
    "@uv-alarm/shared": "workspace:*",
    "lucide-react": "^0.536.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.2",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^26.1.0",
    "typescript": "^6.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
