{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "allowSyntheticDefaultImports": true,
    "types": ["node", "vitest/globals"],
    "outDir": "dist"
  },
  "include": ["api", "src", "tests", "drizzle.config.ts"]
}
